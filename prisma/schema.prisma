// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  FACULTY
  STUDENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STUDENT)
  
  // Relations to specific profiles
  admin         Admin?
  faculty       Faculty?
  student       Student?

  exams         Exam[]    @relation("CreatedExams")
  results       Result[]
  notifications Notification[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
  @@index([email])
}

model Admin {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Faculty {
  id           String      @id @default(cuid())
  userId       String      @unique
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  queries      StudentQuery[]
  students     Student[]

  @@index([userId])
  @@index([departmentId])
}

model Student {
  id       String  @id @default(cuid())
  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNo   String? @unique
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id])
  facultyId String?
  faculty   Faculty? @relation(fields: [facultyId], references: [id])
  queries  StudentQuery[]

  @@index([userId])
  @@index([courseId])
  @@index([facultyId])
}

model Department {
  id      String    @id @default(cuid())
  name    String    @unique
  faculty Faculty[]
  courses Course[]
}

model Course {
  id           String     @id @default(cuid())
  name         String
  code         String     @unique
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  students     Student[]
}

model SystemConfig {
  id                 String   @id @default(cuid())
  institutionName    String   @default("Online Exam System")
  institutionAddress String?
  contactEmail       String?
  contactPhone       String?
  logoUrl            String?
  maintenanceMode    Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Exam {
  id          String     @id @default(cuid())
  title       String
  description String?
  duration    Int        // In minutes
  startTime   DateTime?  
  expiresAt   DateTime?  
  creatorId   String
  creator     User       @relation("CreatedExams", fields: [creatorId], references: [id])
  questions   Question[]
  results     Result[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([creatorId])
  @@index([createdAt])
}

model Question {
  id            String   @id @default(cuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  text          String
  options       String[] // Next.js handles this as an array
  correctAnswer Int      // Index of the correct option (e.g., 0, 1, 2, 3)

  @@index([examId])
}

model Result {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  score     Int
  total     Int
  answers   Json?    
  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([examId])
  @@index([createdAt])
}

model StudentQuery {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  facultyId String?
  faculty   Faculty? @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  question  String   @db.Text
  answer    String?  @db.Text
  isResolved Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([facultyId])
  @@index([isResolved])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}